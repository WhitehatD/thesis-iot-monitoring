{
  "version": 1,
  "description": "Context-aware policy rules for PreToolUse hook. First match wins.",
  "rules": [

    {"id": "git-force-push-main", "match": "git\\s+push\\s+.*--force", "condition": {"branch": "main|master"}, "action": "block", "message": "Force push to main/master is never allowed"},
    {"id": "git-force-push", "match": "git\\s+push\\s+.*--force", "action": "gate", "message": "Force push requires approval"},
    {"id": "git-push-main", "match": "git\\s+push", "condition": {"branch": "main|master"}, "action": "gate", "message": "Push to main requires approval"},
    {"id": "git-push", "match": "git\\s+push", "action": "allow"},
    {"id": "git-reset-hard", "match": "git\\s+reset\\s+--hard", "action": "gate", "message": "Hard reset requires approval"},
    {"id": "git-checkout-discard", "match": "git\\s+checkout\\s+--\\s+\\.", "action": "gate", "message": "Discard all changes requires approval"},
    {"id": "git-clean", "match": "git\\s+clean\\s+-[a-zA-Z]*f", "action": "gate", "message": "git clean -f removes untracked files permanently"},
    {"id": "git-branch-delete", "match": "git\\s+branch\\s+-D", "action": "warn", "message": "Force-deleting branch -- verify it has been merged"},
    {"id": "git-rebase-main", "match": "git\\s+rebase", "condition": {"branch": "main|master"}, "action": "gate", "message": "Rebase on main requires approval"},

    {"id": "rm-system", "match": "rm\\s+.*/(etc|usr|bin|sbin|boot|lib|var|Windows|Program)", "action": "block", "message": "Delete targeting system directory"},
    {"id": "rm-outside-project", "match": "rm\\s+-[a-zA-Z]*r", "condition": {"path_outside_project": true}, "action": "block", "message": "Recursive delete outside project"},
    {"id": "rm-tmp", "match": "rm\\s+", "condition": {"path": "/tmp/*"}, "action": "allow"},
    {"id": "rm-node-modules", "match": "rm\\s+-[a-zA-Z]*r[a-zA-Z]*\\s+.*node_modules", "action": "allow"},
    {"id": "rm-general", "match": "rm\\s+", "action": "warn", "message": "File deletion -- verify target"},

    {"id": "chmod-outside", "match": "chmod", "condition": {"path_outside_project": true}, "action": "gate", "message": "chmod outside project requires approval"},
    {"id": "chown", "match": "chown", "action": "gate", "message": "Ownership change requires approval"},
    {"id": "mv-outside", "match": "mv\\s+", "condition": {"path_outside_project": true}, "action": "warn", "message": "Moving files outside project -- verify paths"},

    {"id": "deploy-main", "match": "docker\\s+compose\\s+up|docker-compose\\s+up", "condition": {"branch": "main|master"}, "action": "allow"},
    {"id": "deploy-nonmain", "match": "docker\\s+compose\\s+up|docker-compose\\s+up", "action": "warn", "message": "Deploying from non-main branch"},
    {"id": "docker-prune", "match": "docker\\s+(system|volume|image)\\s+prune", "action": "gate", "message": "Docker prune requires approval"},
    {"id": "docker-stop-all", "match": "docker\\s+stop\\s+\\$\\(", "action": "gate", "message": "Stopping all containers requires approval"},
    {"id": "docker-rm-volume", "match": "docker\\s+volume\\s+rm", "action": "warn", "message": "Removing Docker volume -- data loss possible"},

    {"id": "ssh-destructive", "match": "ssh\\s+.*\\b(rm|shutdown|reboot|halt|poweroff|dd|mkfs)\\b", "action": "block", "message": "Destructive remote command"},
    {"id": "ssh-sudo", "match": "ssh\\s+.*\\bsudo\\b", "action": "warn", "message": "Remote sudo command -- verify intent"},
    {"id": "ssh", "match": "ssh\\s+", "action": "allow"},

    {"id": "publish-pkg", "match": "npm\\s+publish|cargo\\s+publish|pnpm\\s+publish", "action": "gate", "message": "Publishing package requires approval"},
    {"id": "npm-global", "match": "npm\\s+install\\s+-g|pnpm\\s+add\\s+-g", "action": "warn", "message": "Global package install -- verify intent"},
    {"id": "pkg-install", "match": "npm\\s+install|pnpm\\s+install|pnpm\\s+add|cargo\\s+add|pip\\s+install", "action": "allow"},

    {"id": "kubectl-delete-ns", "match": "kubectl\\s+delete\\s+(namespace|ns)\\b", "action": "block", "message": "Namespace deletion is never allowed via hook"},
    {"id": "kubectl-delete-prod", "match": "kubectl\\s+delete", "condition": {"not_namespace": "default|kube-system|production"}, "action": "warn", "message": "kubectl delete -- verify namespace and target"},
    {"id": "kubectl-delete", "match": "kubectl\\s+delete", "action": "gate", "message": "kubectl delete in sensitive namespace requires approval"},
    {"id": "kubectl-apply", "match": "kubectl\\s+(apply|rollout|scale|get|describe|logs)", "action": "allow"},

    {"id": "systemctl-critical", "match": "systemctl\\s+(stop|disable|mask)\\s+(sshd|docker|nginx|caddy|NetworkManager|firewalld|ufw)", "action": "block", "message": "Stopping critical service"},
    {"id": "systemctl-restart", "match": "systemctl\\s+restart", "action": "warn", "message": "Service restart -- verify target"},
    {"id": "systemctl-read", "match": "systemctl\\s+(status|show|is-active|is-enabled|list)", "action": "allow"},

    {"id": "curl-pipe-sh", "match": "(curl|wget)\\s+.*\\|\\s*(ba)?sh", "action": "block", "message": "Piped remote code execution"},
    {"id": "curl-post-creds", "match": "curl\\s+.*(-u|--user|Authorization)", "action": "warn", "message": "HTTP request with credentials -- verify target"},

    {"id": "env-write", "match": "cat.*>.*\\.env|echo.*>.*\\.env|cp.*\\.env", "action": "warn", "message": "Writing to .env file -- verify no secrets leak"},
    {"id": "env-read", "match": "cat\\s+.*\\.env|grep.*\\.env", "action": "allow"},

    {"id": "crontab-edit", "match": "crontab\\s+-[eir]", "action": "gate", "message": "Crontab modification requires approval"},
    {"id": "iptables", "match": "iptables|nft\\b", "action": "gate", "message": "Firewall rule change requires approval"},

    {"id": "default-pass", "match": ".*", "action": "pass"}
  ]
}
